{
  "_doc": "Bronze — eventos de clickstream web (streaming, particionado por _ingested_date)",
  "catalog":  "{catalog.bronze}",
  "schema":   "ecommerce",
  "name":     "eventos_raw",
  "type":     "MANAGED",
  "format":   "DELTA",
  "comment":  "Clickstream web desde streaming — append_dedup en Silver",
  "owner":    "data-engineering",

  "columns": [
    { "name": "evento_id",      "type": "STRING",    "nullable": false },
    { "name": "cliente_id",     "type": "STRING",    "nullable": true  },
    { "name": "session_id",     "type": "STRING",    "nullable": true  },
    { "name": "tipo_evento",    "type": "STRING",    "nullable": true  },
    { "name": "pagina",         "type": "STRING",    "nullable": true  },
    { "name": "dispositivo",    "type": "STRING",    "nullable": true  },
    { "name": "duracion_seg",   "type": "INTEGER",   "nullable": true  },
    { "name": "timestamp",      "type": "STRING",    "nullable": true  },
    { "name": "_ingested_at",   "type": "TIMESTAMP", "nullable": true, "comment": "Timestamp de ingesta" },
    { "name": "_ingested_date", "type": "DATE",      "nullable": true, "comment": "Fecha de ingesta (particion)" },
    { "name": "_source_file",   "type": "STRING",    "nullable": true, "comment": "Archivo fuente" }
  ],

  "partitions": ["_ingested_date"],

  "properties": {
    "merge_schema": true,
    "quality":      "raw",
    "layer":        "bronze"
  }
}
