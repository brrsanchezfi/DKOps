{
  "_doc": "Ingesta batch de vuelos diarios — incremental (JSON)",
  "name":        "vuelos_diarios",
  "description": "Carga diaria de eventos de vuelos desde Landing hacia Bronze",
  "ingest_type": "batch",
  "load_type":   "incremental",
  "enabled":     true,

  "source": {
    "format": "json",
    "path":   "{path.landing}/vuelos_diarios",
    "options": {
      "multiLine": "false"
    }
  },

  "destination_contract": "../../tables/bronze/vuelos_raw.json",

  "metadata": {
    "add_ingested_at":   true,
    "add_ingested_date": true,
    "add_source_file":   true
  }
}
