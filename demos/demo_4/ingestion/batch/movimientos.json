{
  "_doc": "Ingesta batch de movimientos de inventario — incremental (JSON)",
  "name":        "movimientos",
  "description": "Carga incremental diaria de movimientos desde Landing",
  "ingest_type": "batch",
  "load_type":   "incremental",
  "enabled":     true,

  "source": {
    "format": "json",
    "path":   "{path.landing}/movimientos_inventario",
    "options": { "multiLine": "false" }
  },

  "destination_contract": "../../tables/bronze/movimientos_raw.json",

  "metadata": {
    "add_ingested_at":   true,
    "add_ingested_date": true,
    "add_source_file":   true
  }
}
