{
  "_doc": "Ingesta batch de ventas de manufactura — incremental (CSV)",
  "name":        "ventas_manufactura",
  "description": "Carga incremental diaria de ventas desde Landing hacia Bronze",
  "ingest_type": "batch",
  "load_type":   "incremental",
  "enabled":     true,

  "source": {
    "format": "csv",
    "path":   "{path.landing}/ventas_manufactura",
    "options": {
      "header": "true",
      "inferSchema": "true"
    }
  },

  "destination_contract": "../../tables/bronze_new/ventas_manufactura_raw.json",

  "metadata": {
    "add_ingested_at":   true,
    "add_ingested_date": true,
    "add_source_file":   true
  }
}
