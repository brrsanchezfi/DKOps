{
  "_doc": "Ingesta batch de eventos CDC de ventas — incremental diario",
  "name":        "ventas_diarias",
  "description": "Carga diaria de eventos CDC desde Landing hacia Bronze",
  "ingest_type": "batch",
  "load_type":   "cdc",
  "enabled":     true,

  "source": {
    "format": "json",
    "path":   "{path.landing}/ventas_diarias",
    "options": {
      "multiLine": "false"
    }
  },

  "destination_contract": "../../tables/bronze/ventas_raw.json",

  "metadata": {
    "add_ingested_at":   true,
    "add_ingested_date": true,
    "add_source_file":   true
  }
}
